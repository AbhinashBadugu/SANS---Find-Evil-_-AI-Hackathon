# Copy this file to webui/.env and paste your key (then SAVE the file).
# webui/.env is gitignored, so the key is never committed.
#
# Only the chat box needs this; the dashboard / reports / score work without it.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides:
# DFIR_CHAT_MODEL=claude-sonnet-4-6
# DFIR_UI_PORT=8077
