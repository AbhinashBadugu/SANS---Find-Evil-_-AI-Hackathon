# Copy to .env and adjust for your machine.

# Evidence area — read ONLY. Never written to.
EVIDENCE_ROOT=/cases

# Results area — all output + the provenance logbook go here.
CASE_ROOT=/home/sansforensics/analysis/mcp-cases

# Memory tool. On the SANS SIFT box this is `vol` (NOT vol.py).
VOLATILITY_BIN=vol

# Max seconds any single tool may run.
DEFAULT_TIMEOUT_SECONDS=1800

# Unlock the full approved Volatility plugin set (still an allowlist).
VOL_ALLOWLIST_FULL=1
